@page
@model PhumKasikam.Pages.Blog.BlogModel
@{
    ViewData["Title"] = "អត្ថបទកសិកម្ម";
}

<link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

<div class="container mt-5 pt-3">
    <div class="blog-header p-5 mb-5 text-white rounded-5 shadow-lg position-relative overflow-hidden" data-aos="zoom-in">
        <div class="position-relative z-2">
            <h1 class="display-4 fw-bold animate__animated animate__fadeInDown">ចំណេះដឹងកសិកម្ម</h1>
            <p class="lead my-3 fs-5 opacity-90 animate__animated animate__fadeInUp">
                ប្រភពប្រមូលផ្ដុំនូវបច្ចេកទេសដាំដុះ និងការថែទាំដំណាំគ្រប់ប្រភេទតាមលក្ខណៈបច្គេកទេសទំនើប ២០២៦។
            </p>
        </div>
        <div class="header-overlay"></div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="row g-4">
                @if (Model.Blogs != null && Model.Blogs.Any())
                {
                    var delay = 100;
                    @foreach (var blog in Model.Blogs)
                    {
                        <div class="col-12" data-aos="fade-up" data-aos-delay="@delay">
                            <div class="blog-card row g-0 border-0 rounded-4 overflow-hidden shadow-sm bg-white transition-hover mb-4">
                                <div class="col-md-5">
                                    <div class="h-100 img-container overflow-hidden">
                                        @* 🟢 ដំណោះស្រាយ៖ ឆែកមើលប្រភពរូបភាពសម្រាប់ការបង្ហាញក្នុងបញ្ជីធំ *@
                                        @if (string.IsNullOrEmpty(blog.ImageUrl))
                                        {
                                            <img src="https://placehold.co/600x400" class="img-fluid w-100 h-100 object-fit-cover blog-img" alt="@blog.Title">
                                        }
                                        else if (blog.ImageUrl.StartsWith("http://") || blog.ImageUrl.StartsWith("https://"))
                                        {
                                            <img src="@blog.ImageUrl" class="img-fluid w-100 h-100 object-fit-cover blog-img" alt="@blog.Title">
                                        }
                                        else
                                        {
                                            <img src="@Url.Content("~" + blog.ImageUrl)" class="img-fluid w-100 h-100 object-fit-cover blog-img" alt="@blog.Title">
                                        }
                                    </div>
                                </div>
                                <div class="col-md-7 p-4 d-flex flex-column">
                                    <div class="mb-2">
                                        <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill fw-bold">
                                            <i class="bi bi-tag-fill me-1"></i> បច្ចេកទេសជឿនលឿន
                                        </span>
                                    </div>
                                    <h3 class="mb-2 fw-bold text-dark fs-4 lh-base text-line-2">@blog.Title</h3>
                                    <div class="mb-3 text-muted small">
                                        <i class="bi bi-calendar3 me-1"></i> @blog.CreatedAt.ToString("dd MMMM yyyy")
                                        <span class="mx-2">|</span>
                                        <i class="bi bi-person me-1"></i> ដោយ៖ អ្នកជំនាញកសិកម្ម
                                    </div>
                                    <p class="card-text text-muted mb-4 text-line-3">
                                        @blog.Content
                                    </p>
                                    @* <div class="mt-auto">
                                        <a asp-page="/Blog/Details" asp-route-id="@blog.Id" class="btn btn-link text-success p-0 fw-bold text-decoration-none">
                                            <i class="bi bi-arrow-right ms-1"></i> អានអត្ថបទពេញ
                                        </a>
                                    </div> *@
                                    <div class="mt-auto">
                                        <a asp-page="/Blog/Details" 
                                        asp-route-id="@blog.Id"
                                        class="btn btn-outline-success rounded-pill px-4 py-2 d-inline-flex align-items-center gap-2 blog-read-btn">
                                            
                                            <span>អានអត្ថបទពេញ</span>
                                            <i class="bi bi-arrow-right-short fs-5"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                        delay += 50;
                    }
                }
                else
                {
                    <div class="col-12 text-center py-5 text-muted" data-aos="fade-up">
                        <i class="bi bi-journal-x display-4 d-block mb-3"></i>
                        <h5>មិនទាន់មានអត្ថបទផ្សព្វផ្សាយនៅឡើយទេ</h5>
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-4">
            <div class="sticky-top" style="top: 100px; z-index: 4;">
                <div class="card border-0 shadow-sm rounded-4 mb-4" data-aos="fade-left">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3">ស្វែងរកអត្ថបទ</h5>
                        <div class="input-group">
                            <input type="text" class="form-control rounded-start-pill border-end-0 shadow-none" placeholder="ស្វែងរក...">
                            <button class="btn btn-success rounded-end-pill px-3"><i class="bi bi-search"></i></button>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm rounded-4 mb-4" data-aos="fade-left" data-aos-delay="100">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4 border-bottom pb-2">អត្ថបទថ្មីៗចុងក្រោយ</h5>
                        <div class="popular-post-list">
                            @if (Model.Blogs != null && Model.Blogs.Any())
                            {
                                @foreach (var popular in Model.Blogs.Take(3))
                                {
                                    <div class="d-flex mb-3 align-items-center">
                                        @* 🟢 ដំណោះស្រាយ៖ ឆែកមើលប្រភពរូបភាពសម្រាប់ការបង្ហាញក្នុងបញ្ជី Sidebar ចំហៀង *@
                                        @if (string.IsNullOrEmpty(popular.ImageUrl))
                                        {
                                            <img src="https://placehold.co/100" class="rounded-3 me-3" width="65" height="65" style="object-fit: cover;">
                                        }
                                        else if (popular.ImageUrl.StartsWith("http://") || popular.ImageUrl.StartsWith("https://"))
                                        {
                                            <img src="@popular.ImageUrl" class="rounded-3 me-3" width="65" height="65" style="object-fit: cover;">
                                        }
                                        else
                                        {
                                            <img src="@Url.Content("~" + popular.ImageUrl)" class="rounded-3 me-3" width="65" height="65" style="object-fit: cover;">
                                        }
                                        <div>
                                            <h6 class="mb-1 fw-bold small text-line-2">
                                                <a asp-page="/Blog/Details" asp-route-id="@popular.Id" class="text-dark text-decoration-none hover-success">@popular.Title</a>
                                            </h6>
                                            <span class="text-muted" style="font-size: 0.75rem;">@popular.CreatedAt.ToString("dd MMM yyyy")</span>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-muted small mb-0">គ្មានទិន្នន័យ</p>
                            }
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm rounded-4" data-aos="fade-left" data-aos-delay="200">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3 border-bottom pb-2">ប្រភេទអត្ថបទ</h5>
                        <ul class="list-unstyled mb-0">
                            <li class="mb-2"><a href="#" class="text-decoration-none text-muted d-flex justify-content-between"><span><i class="bi bi-chevron-right small"></i> បច្ចេកទេសដាំដុះ</span> <span class="badge bg-light text-dark rounded-pill">@((Model.Blogs != null) ? Model.Blogs.Count : 0)</span></a></li>
                            <li class="mb-2"><a href="#" class="text-decoration-none text-muted d-flex justify-content-between"><span><i class="bi bi-chevron-right small"></i> ការប្រើប្រាស់ជី</span> <span class="badge bg-light text-dark rounded-pill">0</span></a></li>
                            <li class="mb-2"><a href="#" class="text-decoration-none text-muted d-flex justify-content-between"><span><i class="bi bi-chevron-right small"></i> ការពារសត្វល្អិត</span> <span class="badge bg-light text-dark rounded-pill">0</span></a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        AOS.init({
            duration: 800,
            easing: 'ease-in-out',
            once: true
        });
    });
</script>

<style>
    /* Header Styling */
    .blog-header {
        background: linear-gradient(135deg, #198754 0%, #0d5233 100%);
        min-height: 260px;
        display: flex;
        align-items: center;
    }
    .header-overlay {
        position: absolute; top: 0; left: 0; width: 100%; height: 100%;
        background-image: url('https://www.transparenttextures.com/patterns/leaf.png');
        opacity: 0.1;
    }
    .z-2 { z-index: 2; }

    /* Blog Card Customization */
    .blog-card {
        transition: all 0.4s ease;
        border: 1px solid rgba(0,0,0,0.03) !important;
    }
    .transition-hover:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
    }
    .blog-img {
        transition: transform 0.6s ease;
        min-height: 230px;
    }
    .blog-card:hover .blog-img {
        transform: scale(1.08);
    }
    .object-fit-cover { object-fit: cover; }
    .bg-success-subtle { background-color: #e8f5e9; }

    /* Sidebar Links & Utils */
    .list-unstyled li a:hover {
        color: #198754 !important;
        padding-left: 5px;
        transition: all 0.3s ease;
    }
    .hover-success:hover {
        color: #198754 !important;
    }

    /* Text Truncation */
    .text-line-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;  
        overflow: hidden;
    }
    .text-line-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;  
        overflow: hidden;
    }
    .blog-read-btn{
    transition: all 0.3s ease;
    font-weight: 600;
}

.blog-read-btn:hover{
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(25,135,84,0.15);
}

.blog-read-btn i{
    transition: transform 0.3s ease;
}

.blog-read-btn:hover i{
    transform: translateX(4px);
}

    @@media (max-width: 991px) {
        .sticky-top { position: relative !important; top: 0 !important; margin-top: 3rem; }
    }
</style>