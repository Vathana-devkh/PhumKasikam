@page
@model PhumKasikam.Pages.Blog.DetailsModel
@{
    ViewData["Title"] = Model.BlogItem?.Title ?? "бһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“бһўбһҸбҹ’бһҗбһ”бһ‘";
}

<link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

<div class="container mt-5 pt-4">
    @if (Model.BlogItem != null)
    {
        <div class="row justify-content-center">
            <div class="col-lg-9">
                <div class="mb-4" data-aos="fade-right">
                    <a asp-page="/Blog/blog" class="btn btn-light rounded-pill px-4 text-success fw-bold shadow-sm border-0">
                        <i class="bi bi-arrow-left me-2"></i> бһҸбҹ’бһҡбһӣбһ”бҹӢбһ‘бҹ…бһ‘бҹҶбһ–бҹҗбһҡбһҳбһ»бһ“
                    </a>
                </div>

                <article class="bg-white rounded-5 p-4 p-md-5 shadow-sm overflow-hidden border border-light mb-5" data-aos="fade-up">
                    
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill fw-bold">
                            <i class="bi bi-tag-fill me-1"></i> бһ”бһ…бҹ’бһ…бҹҒбһҖбһ‘бҹҒбһҹбһҮбһҝбһ“бһӣбһҝбһ“
                        </span>
                        <span class="text-muted small">
                            <i class="bi bi-calendar3 me-1"></i> @Model.BlogItem.CreatedAt.ToString("dd MMMM yyyy")
                        </span>
                    </div>

                    <h1 class="fw-bold text-dark lh-base mb-4 display-6">@Model.BlogItem.Title</h1>

                    <div class="d-flex align-items-center gap-3 border-bottom pb-4 mb-4 text-muted small">
                        <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                            <i class="bi bi-person-fill fs-5"></i>
                        </div>
                        <div>
                            <p class="mb-0 fw-bold text-dark">бһҠбҹ„бһҷбҹ– бһўбҹ’бһ“бһҖбһҮбҹҶбһ“бһ¶бһүбһҖбһҹбһ·бһҖбһҳбҹ’бһҳ Phum Kasikam</p>
                            <p class="mb-0 text-muted" style="font-size: 0.75rem;">бһ•бҹ’бһҹбһ–бҹ’бһңбһ•бҹ’бһҹбһ¶бһҷбһҮбһ¶бһ…бҹҶбһҺбҹҒбҹҮбһҠбһ№бһ„бһ‘бһјбһ‘бҹ…</p>
                        </div>
                    </div>

                    <div class="rounded-4 overflow-hidden mb-5 bg-light shadow-sm" style="max-height: 480px;">
                        @if (string.IsNullOrEmpty(Model.BlogItem.ImageUrl))
                        {
                            <img src="https://placehold.co/1200x600" class="w-100 h-100 object-fit-cover img-fluid" style="object-fit: cover;" alt="@Model.BlogItem.Title">
                        }
                        else if (Model.BlogItem.ImageUrl.StartsWith("http://") || Model.BlogItem.ImageUrl.StartsWith("https://"))
                        {
                            <img src="@Model.BlogItem.ImageUrl" class="w-100 h-100 object-fit-cover img-fluid" style="object-fit: cover;" alt="@Model.BlogItem.Title">
                        }
                        else
                        {
                            <img src="@Url.Content("~" + Model.BlogItem.ImageUrl)" class="w-100 h-100 object-fit-cover img-fluid" style="object-fit: cover;" alt="@Model.BlogItem.Title">
                        }
                    </div>

                    <div class="blog-detailed-content text-dark lh-lg fs-5 mb-4" style="white-space: pre-line; text-align: justify;">
                        @Model.BlogItem.Content
                    </div>
                </article>

                <div class="related-blogs-section mb-5" data-aos="fade-up">
                    <h4 class="fw-bold text-dark mb-4 position-relative pb-2 section-title">
                        <i class="bi bi-journal-text text-success me-2"></i> бһўбһҸбҹ’бһҗбһ”бһ‘бһ•бҹ’бһҹбҹҒбһ„бһ‘бҹҖбһҸбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһўбһ¶бһ“
                    </h4>
                    
                    <div class="row g-4">
                        @if (Model.RelatedBlogs != null && Model.RelatedBlogs.Any())
                        {
                            @foreach (var related in Model.RelatedBlogs)
                            {
                                <div class="col-md-4">
                                    <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden related-card bg-white">
                                        <div class="position-relative overflow-hidden" style="height: 160px;">
                                            @if (string.IsNullOrEmpty(related.ImageUrl))
                                            {
                                                <img src="https://placehold.co/400x250" class="w-100 h-100 object-fit-cover related-img" alt="@related.Title">
                                            }
                                            else if (related.ImageUrl.StartsWith("http://") || related.ImageUrl.StartsWith("https://"))
                                            {
                                                <img src="@related.ImageUrl" class="w-100 h-100 object-fit-cover related-img" alt="@related.Title">
                                            }
                                            else
                                            {
                                                <img src="@Url.Content("~" + related.ImageUrl)" class="w-100 h-100 object-fit-cover related-img" alt="@related.Title">
                                            }
                                        </div>
                                        <div class="card-body p-3 d-flex flex-column">
                                            <span class="text-muted small d-block mb-1">
                                                <i class="bi bi-calendar3 me-1"></i> @related.CreatedAt.ToString("dd MMM yyyy")
                                            </span>
                                            <h6 class="card-title fw-bold text-dark text-line-2 mb-3 lh-base fs-6">
                                                <a asp-page="/Blog/Details" asp-route-id="@related.Id" class="text-dark text-decoration-none hover-success">
                                                    @related.Title
                                                </a>
                                            </h6>
                                            <div class="mt-auto">
                                                <a asp-page="/Blog/Details" asp-route-id="@related.Id" class="text-success small fw-bold text-decoration-none d-inline-flex align-items-center">
                                                    бһўбһ¶бһ“бһ”бһ“бҹ’бһҸ <i class="bi bi-chevron-right ms-1 small"></i>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="col-12">
                                <p class="text-muted small">бһҳбһ·бһ“бһ‘бһ¶бһ“бҹӢбһҳбһ¶бһ“бһўбһҸбҹ’бһҗбһ”бһ‘бһ•бҹ’бһҹбҹҒбһ„бһ‘бҹҖбһҸбһ‘бҹҒбҹ”</p>
                            </div>
                        }
                    </div>
                </div>

            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5 my-5" data-aos="fade-up">
            <i class="bi bi-exclamation-circle display-1 text-danger mb-3"></i>
            <h3 class="fw-bold">бһҡбһҖбһҳбһ·бһ“бһғбһҫбһүбһўбһҸбҹ’бһҗбһ”бһ‘бһҠбҹӮбһӣбһўбҹ’бһ“бһҖбһҖбҹҶбһ–бһ»бһ„бһҹбҹ’бһңбҹӮбһ„бһҡбһҖбһ‘бҹҒ!</h3>
            <p class="text-muted">бһўбһҸбҹ’бһҗбһ”бһ‘бһ“бҹҒбҹҮбһўбһ¶бһ…бһ“бһ№бһ„бһҸбҹ’бһҡбһјбһңбһӣбһ»бһ” бһ¬бһ•бҹ’бһӣбһ¶бһҹбҹӢбһ”бҹ’бһҸбһјбһҡбһ‘бһёбһҸбһ¶бҹҶбһ„бһ”бһ¶бһҸбҹӢбһ‘бҹ…бһ бһҫбһҷбҹ”</p>
            <a asp-page="/Blog/blog" class="btn btn-success rounded-pill px-4 mt-3">бһҸбҹ’бһҡбһӣбһ”бҹӢбһ‘бҹ…бһ‘бҹҶбһ–бҹҗбһҡбһўбһҸбҹ’бһҗбһ”бһ‘</a>
        </div>
    }
</div>

<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        AOS.init({
            duration: 800,
            easing: 'ease-in-out',
            once: true
        });
    });
</script>

<style>
    .bg-success-subtle { background-color: #e8f5e9; }
    .blog-detailed-content {
        font-family: 'Kantumruy Pro', sans-serif;
        color: #2b2b2b !important;
    }
    
    /* рҹҹў Custom Style бһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢ Related Posts */
    .section-title::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 50px;
        height: 3px;
        background-color: #198754;
        border-radius: 2px;
    }
    .related-card {
        border: 1px solid rgba(0,0,0,0.02) !important;
        transition: all 0.3s ease;
    }
    .related-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
    }
    .related-img {
        transition: transform 0.5s ease;
    }
    .related-card:hover .related-img {
        transform: scale(1.06);
    }
    .hover-success:hover {
        color: #198754 !important;
    }
    .text-line-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;  
        overflow: hidden;
    }
</style>