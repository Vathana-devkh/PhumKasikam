@page
@model IndexModel
@{
    ViewData["Title"] = "ទំព័រដើម";
}

<link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

<div id="heroCarousel" class="carousel slide carousel-fade shadow-sm" data-bs-ride="carousel">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2"></button>
    </div>

    <div class="carousel-inner rounded-bottom-5 overflow-hidden">
        <div class="carousel-item active" data-bs-interval="1500">
            <div class="slide-overlay" style="background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.6)), url('@Url.Content("~/images/banner-farm-1.jpg")');">
                <div class="container h-100 d-flex align-items-center justify-content-center text-center">
                    <div class="carousel-caption-custom">
                        <span class="badge bg-warning text-dark mb-3 px-3 py-2 rounded-pill fw-bold animate__animated animate__fadeInDown">បច្ចេកវិទ្យាកសិកម្ម ២០២៦</span>
                        <h1 class="display-3 fw-bold text-white mb-3 animate__animated animate__fadeInDown">ស្វាគមន៍មកកាន់ ភូមិកសិកម្ម</h1>
                        <p class="fs-4 text-white-50 mb-4 animate__animated animate__fadeInUp">ប្រភពចំណេះដឹង និងបច្ចេកទេសកសិកម្មឈានមុខគេ ដើម្បីនិរន្តរភាពកសិករខ្មែរ</p>
                        <div class="d-flex justify-content-center gap-3">
                            <a href="#crops-list" class="btn btn-success btn-lg px-4 rounded-pill shadow">ស្វែងយល់បន្ថែម</a>
                            <a asp-page="/Market/market" class="btn btn-outline-light btn-lg px-4 rounded-pill">ទីផ្សារទិញ-លក់</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="carousel-item" data-bs-interval="1500">
            <div class="slide-overlay" style="background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.6)), url('@Url.Content("~/images/banner-farm-2.jpg")');">
                <div class="container h-100 d-flex align-items-center justify-content-center text-center">
                    <div class="carousel-caption-custom text-white">
                        <h1 class="display-3 fw-bold mb-3">បច្ចេកទេសដាំដុះទំនើប</h1>
                        <p class="fs-4 text-white-50 mb-4">រៀនពីវិធីសាស្ត្របង្កើនទិន្នផល និងការប្រើប្រាស់ជីធម្មជាតិឱ្យត្រូវខ្នាត</p>
                        <a asp-page="/Blog/blog" class="btn btn-warning btn-lg px-4 rounded-pill shadow fw-bold">អានអត្ថបទបច្ចេកទេស</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="carousel-item" data-bs-interval="1500">
            <div class="slide-overlay" style="background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.6)), url('@Url.Content("~/images/banner-farm-3.jpg")');">
                <div class="container h-100 d-flex align-items-center justify-content-center text-center">
                    <div class="carousel-caption-custom text-white">
                        <h1 class="display-3 fw-bold mb-3">ទីផ្សារកសិផលធំជាងគេ</h1>
                        <p class="fs-4 text-white-50 mb-4">ជួយសម្រួលដល់ការនាំចេញកសិផលផ្ទាល់ពីចម្ការទៅកាន់ទីផ្សារ</p>
                        <a asp-page="/Market/market" class="btn btn-success btn-lg px-4 rounded-pill shadow">ចូលទៅកាន់ទីផ្សារ</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container mt-n5 position-relative z-3">
    <div class="row g-3 justify-content-center">
        <div class="col-6 col-md-3" data-aos="zoom-in" data-aos-delay="100">
            <div class="card border-0 shadow-sm rounded-4 text-center p-3 transition-hover bg-white">
                <i class="bi bi-people-fill fs-2 text-success"></i>
                <h4 class="fw-bold mt-2 mb-0">10K+</h4>
                <p class="small text-muted mb-0">សមាជិកកសិករ</p>
            </div>
        </div>
        <div class="col-6 col-md-3" data-aos="zoom-in" data-aos-delay="200">
            <div class="card border-0 shadow-sm rounded-4 text-center p-3 transition-hover bg-white">
                <i class="bi bi-journal-text fs-2 text-primary"></i>
                <h4 class="fw-bold mt-2 mb-0">500+</h4>
                <p class="small text-muted mb-0">អត្ថបទបច្ចេកទេស</p>
            </div>
        </div>
        <div class="col-6 col-md-3" data-aos="zoom-in" data-aos-delay="300">
            <div class="card border-0 shadow-sm rounded-4 text-center p-3 transition-hover bg-white">
                <i class="bi bi-shop fs-2 text-warning"></i>
                <h4 class="fw-bold mt-2 mb-0">150+</h4>
                <p class="small text-muted mb-0">ដៃគូទីផ្សារ</p>
            </div>
        </div>
    </div>
</div>

<div class="container mt-5 py-4">
    <div class="text-center mb-5" data-aos="fade-up">
        <h2 class="fw-bold text-dark">ស្វែងរកតាមប្រភេទដំណាំ</h2>
        <div class="mx-auto" style="width: 60px; height: 3px; background: #198754;"></div>
    </div>
    <div class="row g-4">
        <div class="col-md-4" data-aos="fade-right" data-aos-delay="100">
            <div class="category-box rounded-4 p-4 text-white d-flex align-items-end shadow-sm" 
                 style="background: linear-gradient(rgba(0,0,0,0.2), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1518977676601-b53f02bad65b?auto=format&fit=crop&w=500&q=80'); height: 200px; background-size: cover;">
                <h4 class="fw-bold mb-0">បន្លែបង្ការ</h4>
            </div>
        </div>
        <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
            <div class="category-box rounded-4 p-4 text-white d-flex align-items-end shadow-sm" 
                 style="background: linear-gradient(rgba(0,0,0,0.2), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1619566636858-adf3ef46400b?auto=format&fit=crop&w=500&q=80'); height: 200px; background-size: cover;">
                <h4 class="fw-bold mb-0">ផ្លែឈើស្រស់</h4>
            </div>
        </div>
        <div class="col-md-4" data-aos="fade-left" data-aos-delay="300">
            <div class="category-box rounded-4 p-4 text-white d-flex align-items-end shadow-sm" 
                 style="background: linear-gradient(rgba(0,0,0,0.2), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1536657464919-892534f60d6e?auto=format&fit=crop&w=500&q=80'); height: 200px; background-size: cover;">
                <h4 class="fw-bold mb-0">គ្រឿងទេស</h4>
            </div>
        </div>
    </div>
</div>

<div class="container" id="crops-list">
    <div class="d-flex justify-content-between align-items-center mb-4 mt-5" data-aos="fade-right">
        <h3 class="fw-bold"><i class="bi bi-stars text-warning"></i> ដំណាំណែនាំសម្រាប់ខែនេះ</h3>
        <a asp-page="/Crops/crops" class="btn btn-link text-success text-decoration-none fw-bold">មើលទាំងអស់ <i class="bi bi-arrow-right"></i></a>
    </div>

    <div class="row">
        @if (Model.Crops != null && Model.Crops.Any())
        {
            var delay = 100;
            @foreach (var crop in Model.Crops)
            {
                <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="@delay">
                    <div class="card h-100 shadow-sm border-0 transition-hover overflow-hidden rounded-4">
                        <div class="position-relative">
                            @if (string.IsNullOrEmpty(crop.ImageUrl))
                            {
                                <img src="https://placehold.co/600x400?text=គ្មានរូបភាព" class="card-img-top" alt="@crop.Name" style="height: 220px; object-fit: cover;">
                            }
                            else if (crop.ImageUrl.StartsWith("http://") || crop.ImageUrl.StartsWith("https://"))
                            {
                                <img src="@crop.ImageUrl" class="card-img-top" alt="@crop.Name" style="height: 220px; object-fit: cover;">
                            }
                            else
                            {
                                <img src="@Url.Content("~" + crop.ImageUrl)" class="card-img-top" alt="@crop.Name" style="height: 220px; object-fit: cover;">
                            }
                            <span class="position-absolute top-0 end-0 m-3 badge bg-success shadow">@crop.Category</span>
                        </div>
                        
                        <div class="card-body p-4">
                            <h5 class="card-title fw-bold text-dark">@crop.Name</h5>
                            <p class="card-text text-muted" style="font-size: 0.9rem; line-height: 1.6;">
                                @(crop.Description?.Length > 85 ? crop.Description.Substring(0, 85) + "..." : crop.Description)
                            </p>
                            <a href="#" class="btn btn-link text-success p-0 fw-bold text-decoration-none">អានបច្ចេកទេស <i class="bi bi-arrow-right"></i></a>
                        </div>
                    </div>
                </div>
                delay += 100;
            }
        }
        else
        {
            <div class="col-12 text-center py-5" data-aos="fade-in">
                <div class="alert alert-light border shadow-sm p-5 rounded-4 text-center">
                    <i class="bi bi-exclamation-circle text-muted mb-3" style="font-size: 3rem;"></i>
                    <p class="text-muted mb-0">មិនទាន់មានទិន្នន័យដំណាំនៅក្នុងប្រព័ន្ធនៅឡើយទេ...</p>
                </div>
            </div>
        }
    </div>
</div>

<div class="container-fluid py-5 bg-success bg-opacity-10 mt-5">
    <div class="container">
        <div class="text-center mb-5" data-aos="fade-up">
            <h6 class="text-success fw-bold text-uppercase" style="letter-spacing: 2px;">សក្ខីកម្ម</h6>
            <h2 class="fw-bold text-dark">មតិយោបល់ពីកសិករ</h2>
            <div class="mx-auto mt-2" style="width: 50px; height: 3px; background: #198754;"></div>
        </div>
        <div class="row g-4">
            <div class="col-lg-4" data-aos="flip-left" data-aos-delay="100">
                <div class="card border-0 shadow-sm rounded-4 p-4 h-100 position-relative transition-hover bg-white">
                    <i class="bi bi-quote fs-1 text-success opacity-25 position-absolute top-0 end-0 m-3"></i>
                    <p class="text-muted italic mb-4">"ចាប់តាំងពីខ្ញុំបានប្រើប្រាស់បច្ចេកទេសពី ភូមិកសិកម្ម មក ទិន្នផលរបស់ខ្ញុំបានកើនឡើងទ្វេដង។"</p>
                    <div class="d-flex align-items-center mt-auto">
                        <img src="https://ui-avatars.com/api/?name=Farmer+A&background=198754&color=fff" class="rounded-circle me-3" width="45">
                        <div><h6 class="fw-bold mb-0 small">លោក ពៅ សំណាង</h6><span class="text-muted" style="font-size: 0.7rem;">កសិករខេត្តបាត់ដំបង</span></div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4" data-aos="flip-left" data-aos-delay="200">
                <div class="card border-0 shadow-sm rounded-4 p-4 h-100 position-relative transition-hover bg-white">
                    <i class="bi bi-quote fs-1 text-success opacity-25 position-absolute top-0 end-0 m-3"></i>
                    <p class="text-muted italic mb-4">"វេទិកានេះជួយឱ្យខ្ញុំរកទីផ្សារបានកាន់តែលឿន និងមានតម្លៃសមរម្យ។"</p>
                    <div class="d-flex align-items-center mt-auto">
                        <img src="https://ui-avatars.com/api/?name=Farmer+B&background=198754&color=fff" class="rounded-circle me-3" width="45">
                        <div><h6 class="fw-bold mb-0 small">អ្នកស្រី សុខ ឃីម</h6><span class="text-muted" style="font-size: 0.7rem;">ម្ចាស់ចម្ការបន្លែ</span></div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4" data-aos="flip-left" data-aos-delay="300">
                <div class="card border-0 shadow-sm rounded-4 p-4 h-100 position-relative transition-hover bg-white">
                    <i class="bi bi-quote fs-1 text-success opacity-25 position-absolute top-0 end-0 m-3"></i>
                    <p class="text-muted italic mb-4">"អត្ថបទបច្ចេកទេសងាយស្រួលយល់ និងអនុវត្តតាមបំផុត។ ជាជំនួយដ៏ល្អសម្រាប់កសិករ។"</p>
                    <div class="d-flex align-items-center mt-auto">
                        <img src="https://ui-avatars.com/api/?name=Farmer+C&background=198754&color=fff" class="rounded-circle me-3" width="45">
                        <div><h6 class="fw-bold mb-0 small">លោក ចាន់ ធី</h6><span class="text-muted" style="font-size: 0.7rem;">កសិករវ័យក្មេង</span></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container py-5 mt-4">
    <h2 class="fw-bold text-dark mb-4 text-center" data-aos="fade-up">សកម្មភាព និងសមិទ្ធផល</h2>
    <div class="row g-3">
        <div class="col-md-4 col-6" data-aos="zoom-in">
            <div class="gallery-item rounded-4 overflow-hidden shadow-sm h-100 position-relative">
                <img src="https://images.unsplash.com/photo-1523348837708-15d4a09cfac2?auto=format&fit=crop&w=600" class="img-fluid w-100 h-100 object-fit-cover">
                <div class="gallery-overlay"><span class="text-white fw-bold">ចុះពិនិត្យដំណាំ</span></div>
            </div>
        </div>
        <div class="col-md-4 col-6" data-aos="zoom-in" data-aos-delay="100">
            <div class="gallery-item rounded-4 overflow-hidden shadow-sm h-100 position-relative">
                <img src="https://images.unsplash.com/photo-1592982537447-7440770cbfc9?auto=format&fit=crop&w=600" class="img-fluid w-100 h-100 object-fit-cover">
                <div class="gallery-overlay"><span class="text-white fw-bold">ការប្រមូលផល</span></div>
            </div>
        </div>
        <div class="col-md-4 col-12" data-aos="zoom-in" data-aos-delay="200">
            <div class="gallery-item rounded-4 overflow-hidden shadow-sm h-100 position-relative">
                <img src="https://images.unsplash.com/photo-1560493676-04071c5f467b?auto=format&fit=crop&w=600" class="img-fluid w-100 h-100 object-fit-cover" style="min-height: 200px;">
                <div class="gallery-overlay"><span class="text-white fw-bold">បច្ចេកវិទ្យាថ្មី</span></div>
            </div>
        </div>
    </div>
</div>

<div class="container my-5 pb-5" data-aos="zoom-out-up">
    <div class="card border-0 rounded-5 p-5 bg-dark text-white text-center overflow-hidden position-relative">
        <div class="position-absolute top-0 start-0 w-100 h-100 opacity-25" style="background-image: url('https://www.transparenttextures.com/patterns/leaf.png');"></div>
        <div class="position-relative z-1">
            <h2 class="display-5 fw-bold mb-3">ត្រៀមខ្លួនអភិវឌ្ឍចម្ការរបស់អ្នកហើយឬនៅ?</h2>
            <a asp-page="/Contact" class="btn btn-warning btn-lg px-5 rounded-pill fw-bold text-dark shadow mt-3">ទាក់ទងមកយើងឥឡូវនេះ</a>
        </div>
    </div>
</div>

<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        AOS.init({
            duration: 800,
            easing: 'ease-in-out',
            once: true,
            offset: 100
        });
    });
</script>

<style>
    /* Global Styles */
    .mt-n5 { margin-top: -50px; }
    .z-3 { z-index: 3; }
    .object-fit-cover { object-fit: cover; }
    .rounded-bottom-5 { border-bottom-left-radius: 3rem !important; border-bottom-right-radius: 3rem !important; }

    /* Carousel */
    .slide-overlay { min-height: 550px; background-size: cover; background-position: center; }
    .carousel-caption-custom { max-width: 800px; z-index: 2; background: rgba(0,0,0,0.2); backdrop-filter: blur(5px); padding: 2rem; border-radius: 2rem; }

    /* Categories & Gallery */
    .category-box, .gallery-item { cursor: pointer; transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
    .category-box:hover, .gallery-item:hover { transform: scale(1.05); }
    .gallery-overlay {
        position: absolute; top: 0; left: 0; width: 100%; height: 100%;
        background: linear-gradient(to top, rgba(25, 135, 84, 0.85), transparent);
        display: flex; align-items: flex-end; justify-content: center;
        padding-bottom: 15px; opacity: 0; transition: opacity 0.3s;
    }
    .gallery-item:hover .gallery-overlay { opacity: 1; }

    /* Card Transitions */
    .transition-hover { transition: all 0.4s ease; }
    .transition-hover:hover { transform: translateY(-12px); box-shadow: 0 20px 40px rgba(0,0,0,0.1) !important; }

    /* Responsive */
    @@media (max-width: 768px) {
        .slide-overlay { min-height: 400px; }
        .display-3 { font-size: 2.2rem; }
        .display-5 { font-size: 1.8rem; }
        .rounded-bottom-5 { border-bottom-left-radius: 1.5rem !important; border-bottom-right-radius: 1.5rem !important; }
    }
</style>