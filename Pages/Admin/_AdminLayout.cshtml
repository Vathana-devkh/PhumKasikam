<!DOCTYPE html>
<html lang="km">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Kantumruy+Pro:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --sidebar-bg: #111318;
            --sidebar-hover: rgba(25, 135, 84, 0.15);
            --sidebar-active: #198754;
            --main-bg: #f8fafc;
            --card-shadow: 0 4px 20px 0 rgba(0, 0, 0, 0.03);
        }

        body { 
            background-color: var(--main-bg); 
            font-family: 'Kantumruy Pro', 'Inter', sans-serif;
            overflow-x: hidden;
        }

        /* Modern Sidebar Layout */
        .sidebar { 
            min-height: 100vh; 
            background: var(--sidebar-bg); 
            box-shadow: 4px 0 25px rgba(0,0,0,0.15);
            z-index: 10;
            transition: all 0.3s ease;
        }
        
        .sidebar-brand {
            padding: 24px 20px;
            letter-spacing: 0.5px;
        }

        .sidebar .nav-link { 
            color: #94a3b8; 
            padding: 12px 18px; 
            border-radius: 12px; 
            margin: 4px 14px; 
            font-weight: 500;
            display: flex;
            align-items: center;
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1); 
        }

        .sidebar .nav-link i { 
            font-size: 1.25rem;
            transition: transform 0.25s ease;
        }

        /* Hover & Active States */
        .sidebar .nav-link:hover { 
            background: var(--sidebar-hover); 
            color: #34d399; 
            transform: translateX(4px);
        }

        .sidebar .nav-link:hover i {
            transform: scale(1.1);
        }

        .sidebar .nav-link.active { 
            background: var(--sidebar-active); 
            color: #ffffff !important; 
            box-shadow: 0 8px 16px rgba(25, 135, 84, 0.3);
            transform: none;
        }

        /* Glassmorphism Top Navbar */
        .admin-navbar { 
            background: rgba(255, 255, 255, 0.85); 
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(226, 232, 240, 0.8);
            position: sticky;
            top: 0;
            z-index: 9;
        }

        /* Dropdown Styling */
        .dropdown-menu {
            border-radius: 16px;
            padding: 8px;
            animation: fadeInDropdown 0.2s ease-out;
        }

        .dropdown-item {
            border-radius: 8px;
            padding: 8px 16px;
            font-size: 0.9rem;
            transition: background 0.2s;
        }

        .dropdown-item:hover {
            background-color: #f1f5f9;
        }

        .dropdown-item.text-danger:hover {
            background-color: #fef2f2;
        }

        /* Main Content Container */
        main {
            animation: fadeInContent 0.4s ease-out;
        }

        @@keyframes fadeInDropdown {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @@keyframes fadeInContent {
            from { opacity: 0; transform: translateY(5px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Responsive Text Tweak */
        @@media (max-width: 768px) {
            .sidebar .nav-link span { display: none; }
            .sidebar .nav-link { justify-content: center; margin: 6px 8px; padding: 12px; }
            .sidebar-brand span { display: none; }
            .sidebar-brand { text-align: center; padding: 20px 0; justify-content: center; }
        }
    </style>
</head>
<body>
    <form id="logoutForm" method="post" asp-page="/Admin/Index" asp-page-handler="Logout" class="d-none"></form>

    <div class="container-fluid p-0 d-flex">
        <div class="sidebar col-auto col-md-3 col-xl-2 px-0 d-flex flex-column">
            <div class="sidebar-brand d-flex align-items-center border-bottom border-secondary border-opacity-10 w-100">
                <a href="/Admin/Dashboard" class="d-flex align-items-center text-white text-decoration-none mx-md-auto gap-2">
                    <span class="fs-5 fw-bold text-success d-flex align-items-center gap-2">
                        <i class="bi bi-patch-check-fill fs-4 text-success"></i> 
                        <span>ភូមិកសិកម្ម</span>
                    </span>
                </a>
            </div>
            
            <ul class="nav nav-pills flex-column mb-auto align-items-center align-items-sm-start w-100 mt-4 px-2" id="menu">
                <li class="w-100">
                    <a href="/Admin/Dashboard" class="nav-link gap-3"> 
                        <i class="bi bi-grid-1x2-fill"></i> <span>Dashboard</span>
                    </a>
                </li>
                <li class="w-100">
                    <a href="/Admin/Crops" class="nav-link gap-3">
                        <i class="bi bi-flower1"></i> <span>គ្រប់គ្រងដំណាំ</span>
                    </a>
                </li>
                <li class="w-100">
                    <a href="/Admin/Blog" class="nav-link gap-3">
                        <i class="bi bi-journal-richtext"></i> <span>គ្រប់គ្រងអត្ថបទ</span>
                    </a>
                </li>
                <li class="w-100">
                    <a href="/Admin/Products" class="nav-link gap-3">
                        <i class="bi bi-journal-richtext"></i> <span>គ្រប់គ្រងផលិតផល</span>
                    </a>
                </li>
                 <li class="w-100">
                    <a href="/Admin/Customers" class="nav-link gap-3">
                        <i class="bi bi-journal-richtext"></i> <span>គ្រប់គ្រងអតិថិជន</span>
                    </a>
                </li>
                <li class="w-100 mt-4 border-top border-secondary border-opacity-10 pt-3">
                    <a href="/" target="_blank" class="nav-link gap-3 text-warning opacity-75">
                        <i class="bi bi-box-arrow-up-right"></i> <span>ទៅកាន់វេបសាយ</span>
                    </a>
                </li>

            </ul>
        </div>

        <div class="col p-0 d-flex flex-column" style="min-height: 100vh;">
            <nav class="navbar navbar-expand-lg admin-navbar px-4 py-3">
                <div class="container-fluid p-0 d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-2">
                        <span class="navbar-text fw-bold text-dark fs-5 mb-0">ប្រព័ន្ធគ្រប់គ្រងទិន្នន័យ</span>
                    </div>
                    
                    <div class="dropdown">
                        <a href="#" class="d-flex align-items-center text-dark text-decoration-none dropdown-toggle bg-light px-3 py-2 rounded-pill shadow-sm border" id="dropdownUser1" data-bs-toggle="dropdown" aria-expanded="false">
                            <img src="https://ui-avatars.com/api/?name=Noy+Vathana&background=198754&color=fff" alt="admin profile" width="28" height="28" class="rounded-circle me-2">
                            <span class="d-none d-sm-inline mx-1 fw-bold text-secondary fs-6">ណយ វឌ្ឍនា</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2" aria-labelledby="dropdownUser1">
                            <li><a class="dropdown-item d-flex align-items-center gap-2" href="#"><i class="bi bi-person text-muted"></i> ប្រវត្តិរូប</a></li>
                            <li><hr class="dropdown-divider text-light"></li>
                            <li>
                                <a id="logoutBtn" class="dropdown-item text-danger d-flex align-items-center gap-2" href="#">
                                    <i class="bi bi-box-arrow-left"></i>
                                    ចាកចេញ
                                </a>
                            </li>

                        </ul>
                    </div>
                </div>
            </nav>

            <main class="p-4 flex-grow-1">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const currentPath = window.location.pathname.toLowerCase();
            const navLinks = document.querySelectorAll("#menu .nav-link");

            navLinks.forEach(link => {
                const linkPath = link.getAttribute("href").toLowerCase();
                if (currentPath === linkPath || (linkPath !== "/" && currentPath.startsWith(linkPath))) {
                    link.classList.add("active");
                } else {
                    link.classList.remove("active");
                }
            });
        });

        document.getElementById("logoutBtn").addEventListener("click", function (e) {
            e.preventDefault();
            
            if (confirm("តើអ្នកប្រាកដថាចង់ចាកចេញពីប្រព័ន្ធទេ?")) {
                // 💡 បញ្ជាឱ្យ Form បាញ់ប្រភេទ POST ទៅកាន់ .NET Backend ដោយសុវត្ថិភាព
                document.getElementById("logoutForm").submit();
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>