@page
@model PhumKasikam.Pages.Admin.Customers.IndexModel
@{
    ViewData["Title"] = "бһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһҡбһ„бһҖбһ¶бһҡбһҖбһҳбҹ’бһҳбҹүбһ„бҹӢ - Admin";
    Layout = "_AdminLayout";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-dark mb-0"><i class="bi bi-shield-lock-fill text-success"></i> бһ”бҹ’бһҡбһ–бҹҗбһ“бҹ’бһ’бһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһҡбһ„бһҖбһ¶бһҡбһҖбһҳбҹ’бһҳбҹүбһ„бҹӢ бһ“бһ·бһ„бһўбһҸбһ·бһҗбһ·бһҮбһ“</h2>
    <div class="d-flex gap-2">
        <span class="badge bg-success text-white rounded-pill px-3 py-2 fw-bold small shadow-sm">
            <i class="bi bi-cart-check-fill me-1"></i> бһҖбһ¶бһҡбһҖбһҳбҹ’бһҳбҹүбһ„бҹӢбһҹбһҡбһ»бһ”бҹ– @Model.CustomerOrders.Count
        </span>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 bg-white">
            <thead class="table-light text-secondary uppercase small fw-bold">
                <tr>
                    <th class="ps-4">бһўбһҸбһ·бһҗбһ·бһҮбһ“</th>
                    <th>бһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“бһ‘бҹҶбһ“бһ¶бһҖбҹӢбһ‘бҹҶбһ“бһ„</th>
                    <th>бһҸбҹҶбһ”бһ“бҹӢбһҡбһҹбҹӢбһ“бҹ…</th>
                    <th>бһўбһ¶бһҹбһҷбһҠбҹ’бһӢбһ¶бһ“бһӣбһҳбҹ’бһўбһ·бһҸ</th>
                    <th>бһҹбҹҒбһңбһ¶бһҠбһ№бһҖбһҮбһүбҹ’бһҮбһјбһ“</th>
                    <th>бһҹбһ¶бһҒбһ¶/бһ”бһүбҹ’бһҮбһҡ</th>
                    <th class="text-center">бһңбһ·бһҖбҹ’бһҖбһҷбһ”бһҸбҹ’бһҡ (Payslip)</th>
                    <th>бһҖбһ¶бһӣбһ”бһҡбһ·бһ…бҹ’бһҶбҹҒбһ‘</th>
                    <th class="text-center">бһҹбҹ’бһҗбһ¶бһ“бһ—бһ¶бһ–</th>
                    <th class="text-end pe-4">бһҹбһҖбһҳбҹ’бһҳбһ—бһ¶бһ–</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.CustomerOrders != null && Model.CustomerOrders.Any())
                {
                    foreach (var item in Model.CustomerOrders)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark" id="name-@item.Id">@item.Name</div>
                            </td>
                            
                            <td>
                                <div class="fw-bold text-success"><i class="bi bi-telephone me-1"></i>@item.Phone</div>
                                @if (!string.IsNullOrEmpty(item.Email))
                                {
                                    <div class="text-muted small"><i class="bi bi-envelope me-1"></i>@item.Email</div>
                                }
                            </td>
                            
                            <td>
                                <span class="badge @(item.Region == "phnompenh" ? "bg-primary-subtle text-primary" : "bg-warning-subtle text-warning") rounded-pill px-3 py-2 fw-bold">
                                    @(item.Region == "phnompenh" ? "бһ—бҹ’бһ“бҹҶбһ–бҹҒбһү" : "бһҸбһ¶бһҳбһҒбҹҒбһҸбҹ’бһҸ")
                                </span>
                            </td>

                            <td>
                                <div class="truncate-text text-muted" title="@item.Location">@item.Location</div>
                                <span id="loc-@item.Id" style="display:none;">@item.Location</span>
                            </td>
                            
                            <td>
                                <span class="badge bg-info-subtle text-info rounded-pill px-2 py-1 small">
                                    <i class="bi bi-truck me-1"></i>@item.DeliveryService
                                </span>
                            </td>

                            <td>
                                <div class="text-dark small fw-semibold">@(string.IsNullOrEmpty(item.BranchName) ? "вҖ”" : item.BranchName)</div>
                            </td>
                            
                            <td class="text-center">
                                @if (!string.IsNullOrEmpty(item.PayslipPath))
                                {
                                    <img src="@item.PayslipPath" id="img-@item.Id" class="rounded-3 object-fit-cover border cursor-pointer img-preview-hover" 
                                         style="width: 45px; height: 45px;" 
                                         onclick="openPayslipModal('@item.PayslipPath', '@item.Name')"
                                         title="бһ…бһ»бһ…бһҠбһҫбһҳбҹ’бһ”бһёбһ–бһ·бһ“бһ·бһҸбҹ’бһҷбһҳбһҫбһӣбһңбһ·бһҖбҹ’бһҖбһҷбһ”бһҸбҹ’бһҡбһ–бҹҒбһү">
                                }
                                else
                                {
                                    <span class="text-danger small"><i class="bi bi-exclamation-triangle"></i> бһӮбҹ’бһҳбһ¶бһ“бһҡбһјбһ”бһ—бһ¶бһ–</span>
                                }
                            </td>
                            
                            <td>
                                <div class="text-muted small">@item.OrderDate.ToString("dd-MM-yyyy HH:mm")</div>
                            </td>
                            
                            <td class="text-center">
                                @if (item.Status == "Pending")
                                {
                                    <span class="badge bg-warning text-dark rounded-pill px-2.5 py-1 small"><i class="bi bi-hourglass-split me-1"></i>бһҡбһ„бҹӢбһ…бһ¶бҹҶбһ–бһ·бһ“бһ·бһҸбҹ’бһҷ</span>
                                }
                                else if (item.Status == "Approved")
                                {
                                    <span class="badge bg-success text-white rounded-pill px-2.5 py-1 small"><i class="bi bi-check-circle me-1"></i>бһ”бһ¶бһ“бһҷбһӣбҹӢбһ–бҹ’бһҡбһҳ</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger text-white rounded-pill px-2.5 py-1 small"><i class="bi bi-x-circle me-1"></i>бһ”бһ¶бһ“бһ”бһҠбһ·бһҹбҹҒбһ’</span>
                                }
                            </td>
                            
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-1">
                                    @if (item.Status == "Pending")
                                    {
                                        <button type="button" class="btn btn-sm btn-light text-success rounded-circle" onclick="openActionModal(@item.Id, '@item.Name', 'Approved')" title="бһҷбһӣбҹӢбһ–бҹ’бһҡбһҳбһӣбһҫбһҖбһ¶бһҡбһҖбһҳбҹ’бһҳбҹүбһ„бҹӢ">
                                            <i class="bi bi-check-lg fw-bold"></i>
                                        </button>
                                        <button type="button" class="btn btn-sm btn-light text-danger rounded-circle" onclick="openActionModal(@item.Id, '@item.Name', 'Rejected')" title="бһ”бһҠбһ·бһҹбҹҒбһ’бһҖбһ¶бһҡбһҖбһҳбҹ’бһҳбҹүбһ„бҹӢ">
                                            <i class="bi bi-x-lg fw-bold"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-sm btn-light text-secondary rounded-pill px-2.5 disabled" style="font-size: 0.75rem;">бһҡбһҪбһ…бһҡбһ¶бһӣбҹӢ</button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="10" class="text-center py-5 text-muted">
                            <i class="bi bi-inbox display-4 d-block opacity-25 mb-2"></i>
                            бһҳбһ·бһ“бһ‘бһ¶бһ“бҹӢбһҳбһ¶бһ“бһ‘бһ·бһ“бҹ’бһ“бһ“бҹҗбһҷбһҖбһ¶бһҡбһҖбһҳбҹ’бһҳбҹүбһ„бҹӢбһ–бһёбһўбһҸбһ·бһҗбһ·бһҮбһ“бһ“бҹ…бһЎбһҫбһҷбһ‘бҹҒбҹ”
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="payslipModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-dark" id="payslipModalTitle">бһңбһ·бһҖбҹ’бһҖбһҷбһ”бһҸбҹ’бһҡбһ”бһ„бҹӢбһ”бҹ’бһҡбһ¶бһҖбҹӢ</h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center p-3">
                <img id="fullPayslipImg" src="" class="img-fluid rounded-3 border shadow-sm" style="max-height: 70vh; object-fit: contain;">
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="orderActionModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-body text-center p-4">
                <i id="action-icon" class="display-4 d-block mb-3"></i>
                <h5 class="fw-bold text-dark" id="action-title">бһ”бһүбҹ’бһҮбһ¶бһҖбҹӢбһҹбһҖбһҳбҹ’бһҳбһ—бһ¶бһ–</h5>
                <p class="text-muted small mb-4">бһҸбһҫбһўбҹ’бһ“бһҖбһ–бһ·бһҸбһҮбһ¶бһ…бһ„бҹӢбһ•бҹ’бһӣбһ¶бһҹбҹӢбһ”бҹ’бһҠбһјбһҡбһҹбҹ’бһҗбһ¶бһ“бһ—бһ¶бһ–бһҖбһ¶бһҡбһҖбһҳбҹ’бһҳбҹүбһ„бҹӢбһҡбһ”бһҹбҹӢ В«<span id="action-customer-name" class="fw-bold"></span>В» бһҳбҹӮбһ“бһҠбҹӮбһҡбһ¬бһ‘бҹҒ?</p>
                
                <form method="post" asp-page-handler="UpdateStatus">
                    <input type="hidden" name="id" id="action-id" />
                    <input type="hidden" name="status" id="action-status" />
                    <div class="d-flex gap-2 justify-content-center">
                        <button type="button" class="btn btn-light rounded-pill px-3" data-bs-dismiss="modal">бһ”бҹ„бҹҮбһ”бһ„бҹӢ</button>
                        <button type="submit" id="action-submit-btn" class="btn rounded-pill px-3">бһҷбһӣбҹӢбһ–бҹ’бһҡбһҳ</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // бһҳбһ»бһҒбһ„бһ¶бһҡбһ”бһҫбһҖбһҳбһҫбһӣбһҡбһјбһ”бһ—бһ¶бһ–бһ…бһ»бһ„бһҹбһ“бҹ’бһӣбһ№бһҖбһ”бһ„бҹӢбһ”бҹ’бһҡбһ¶бһҖбҹӢбһ‘бҹҶбһ бҹҶбһ–бҹҒбһү
        function openPayslipModal(path, name) {
            document.getElementById('fullPayslipImg').src = path;
            document.getElementById('payslipModalTitle').innerText = "бһңбһ·бһҖбҹ’бһҖбһҷбһ”бһҸбҹ’бһҡбһ”бһ„бҹӢбһ”бҹ’бһҡбһ¶бһҖбҹӢбҹ– " + name;
            new bootstrap.Modal(document.getElementById('payslipModal')).show();
        }

        // бһҳбһ»бһҒбһ„бһ¶бһҡбһ”бһҫбһҖбһ•бҹ’бһ‘бһ¶бҹҶбһ„бһҷбһӣбҹӢбһ–бҹ’бһҡбһҳ/бһ”бһҠбһ·бһҹбҹҒбһ’бһҖбһ¶бһҡбһҖбһҳбҹ’бһҳбҹүбһ„бҹӢ (бһ•бҹ’бһўбҹӮбһҖбһӣбһҫбһ”бҹҠбһјбһҸбһ„бҹӢбһҠбҹӮбһӣбһ”бһ¶бһ“бһ…бһ»бһ…)
        function openActionModal(id, customerName, status) {
            document.getElementById('action-id').value = id;
            document.getElementById('action-status').value = status;
            document.getElementById('action-customer-name').innerText = customerName;

            const iconElem = document.getElementById('action-icon');
            const titleElem = document.getElementById('action-title');
            const submitBtn = document.getElementById('action-submit-btn');

            if (status === 'Approved') {
                iconElem.className = "bi bi-check-circle-fill text-success display-4 d-block mb-3";
                titleElem.innerText = "бһҷбһӣбҹӢбһ–бҹ’бһҡбһҳбһӣбһҫбһҖбһ¶бһҡбһҖбһҳбҹ’бһҳбҹүбһ„бҹӢ?";
                customerName.className = "fw-bold text-success";
                submitBtn.className = "btn btn-success rounded-pill px-3";
                submitBtn.innerText = "бһҷбһӣбҹӢбһ–бҹ’бһҡбһҳ";
            } else {
                iconElem.className = "bi bi-exclamation-circle-fill text-danger display-4 d-block mb-3";
                titleElem.innerText = "бһ”бһҠбһ·бһҹбҹҒбһ’бһҖбһ¶бһҡбһҖбһҳбҹ’бһҳбҹүбһ„бҹӢ?";
                customerName.className = "fw-bold text-danger";
                submitBtn.className = "btn btn-danger rounded-pill px-3";
                submitBtn.innerText = "бһ”бһҠбһ·бһҹбҹҒбһ’";
            }

            new bootstrap.Modal(document.getElementById('orderActionModal')).show();
        }
    </script>
}

<style>
    .truncate-text {
        width: 160px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        display: block;
    }
    .bg-primary-subtle { background-color: #e3f2fd; color: #0d6efd; }
    .bg-warning-subtle { background-color: #fff3cd; color: #664d03; }
    .bg-success-subtle { background-color: #e8f5e9; color: #198754; }
    .bg-info-subtle { background-color: #e0f7fa; color: #00838f; }
    .table th { font-size: 0.8rem; letter-spacing: 0.5px; }
    .cursor-pointer { cursor: pointer; }
    .img-preview-hover { transition: transform 0.2s ease-in-out; }
    .img-preview-hover:hover { transform: scale(1.1); }
</style>