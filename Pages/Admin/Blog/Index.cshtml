@page
@model PhumKasikam.Pages.Admin.Blog.IndexModel
@{
    ViewData["Title"] = "គ្រប់គ្រងអត្ថបទ";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-dark mb-0"><i class="bi bi-journal-richtext text-primary"></i> គ្រប់គ្រងអត្ថបទកសិកម្ម</h2>
    <button type="button" class="btn btn-primary rounded-pill px-4 shadow-sm" data-bs-toggle="modal"
            data-bs-target="#createBlogModal">
        <i class="bi bi-plus-circle-fill me-2"></i> សរសេរអត្ថបទថ្មី
    </button>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 bg-white">
            <thead class="table-light text-secondary uppercase small fw-bold">
                <tr>
                    <th class="ps-4" style="width: 120px;">រូបភាពក្រប</th>
                    <th>ចំណងជើងអត្ថបទ</th>
                    <th style="width: 150px;">ថ្ងៃបង្កើត</th>
                    <th>ខ្លឹមសារសង្ខេប</th>
                    <th class="text-end pe-4" style="width: 120px;">សកម្មភាព</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.BlogsList != null && Model.BlogsList.Any())
                {
                    @foreach (var item in Model.BlogsList)
                    {
                        <tr>
                            <td class="ps-4">
                                @* 🟢 កែសម្រួល៖ បើវាជា Link ខាងក្រៅ (http) មិនបាច់ប្រើ Url.Content ទេ *@
                                <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://placehold.co/80x50" : (item.ImageUrl.StartsWith("http") ? item.ImageUrl : Url.Content("~" + item.ImageUrl)))"
                                     class="rounded-3 object-fit-cover" width="80" height="50" id="img-@item.Id" alt="@item.Title">
                            </td>
                            <td><span class="fw-bold text-dark" id="title-@item.Id">@item.Title</span></td>
                            <td class="text-muted small">@item.CreatedAt.ToString("dd-MM-yyyy")</td>
                            <td class="text-muted small">
                                <div style="max-width: 350px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" id="content-@item.Id">@item.Content</div>
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group">
                                    <button type="button" class="btn btn-sm btn-outline-primary border-0 rounded-circle me-1"
                                            onclick="openEditModal('@item.Id')" title="កែប្រែ">
                                        <i class="bi bi-pencil-square fs-5"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-outline-danger border-0 rounded-circle"
                                            onclick="openDeleteModal('@item.Id', '@item.Title')" title="លុប">
                                        <i class="bi bi-trash3 fs-5"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            <i class="bi bi-inbox display-6 d-block mb-2"></i> មិនទាន់មានអត្ថបទកសិកម្មនៅឡើយទេ។
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="createBlogModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow rounded-4 overflow-hidden bg-white">
            <div class="modal-header border-bottom-0 pt-4 px-4 px-md-5 d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <div class="icon-shape bg-primary-subtle text-primary rounded-3 p-3 me-3">
                        <i class="bi bi-journal-plus fs-4"></i>
                    </div>
                    <div>
                        <h4 class="modal-title fw-bold text-dark mb-1">សរសេរអត្ថបទកសិកម្មថ្មី</h4>
                        <p class="text-muted small mb-0">ចែករំលែកចំណេះដឹង និងបច្ចេកទេសកសិកម្មថ្មីៗ</p>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form method="post" asp-page-handler="CreateBlog" enctype="multipart/form-data">
                <div class="modal-body px-4 px-md-5 py-3">
                    <div class="row g-4">
                        <div class="col-12">
                            <label asp-for="NewBlog.Title" class="form-label fw-bold text-secondary small">ចំណងជើងអត្ថបទ <span class="text-danger">*</span></label>
                            <input asp-for="NewBlog.Title" class="form-control form-control-lg rounded-3 fs-6" placeholder="បំពេញចំណងជើងអត្ថបទ..." required />
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-bold text-secondary small">រូបភាពក្របមុខ (Thumbnail) <span class="text-danger">*</span></label>
                            
                            <div class="mb-3">
                                <input type="url" name="ImageUrlLink" id="create-image-link" class="form-control rounded-3 fs-6" 
                                       placeholder="ផាសតំណភ្ជាប់រូបភាពនៅទីនេះ (ឧទាហរណ៍៖ https://example.com/image.jpg)..." oninput="previewCreateLinkImage(this.value)" />
                                <div class="form-text text-muted small">ឬ អូសទម្លាក់ហ្វាយរូបភាពខាងក្រោម៖</div>
                            </div>

                            <div class="border border-2 border-dashed rounded-4 p-4 text-center position-relative bg-light transition-hover">
                                <input type="file" name="UploadImage" id="create-file-input" class="position-absolute top-0 start-0 w-100 h-100 opacity-0 cursor-pointer" accept="image/*" onchange="previewCreateImage(event)" />
                                <div id="create-upload-prompt">
                                    <i class="bi bi-cloud-arrow-up display-5 text-primary"></i>
                                    <p class="mb-1 mt-2 fw-bold text-dark">ចុចទីនេះ ឬអូសទម្លាក់រូបភាពដើម្បី Upload</p>
                                </div>
                                <div id="create-image-preview-container" class="d-none">
                                    <img id="create-image-preview" src="#" class="img-fluid rounded-3 shadow-sm object-fit-cover mb-2" style="max-height: 180px;" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <label asp-for="NewBlog.Content" class="form-label fw-bold text-secondary small">ខ្លឹមសារលម្អិតនៃអត្ថបទ <span class="text-danger">*</span></label>
                            <textarea asp-for="NewBlog.Content" class="form-control rounded-3 fs-6" rows="8" placeholder="សរសេរខ្លឹមសារលម្អិតនៅទីនេះ..." required></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pb-4 pt-3 px-4 px-md-5">
                    <button type="button" class="btn btn-lg btn-light rounded-pill px-4 fs-6" data-bs-dismiss="modal">បោះបង់</button>
                    <button type="submit" class="btn btn-lg btn-primary rounded-pill px-5 fs-6 shadow-sm">បោះពុម្ភផ្សាយ</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editBlogModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow rounded-4 overflow-hidden bg-white">
            <div class="modal-header border-bottom-0 pt-4 px-4 px-md-5 d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <div class="icon-shape bg-warning-subtle text-warning rounded-3 p-3 me-3">
                        <i class="bi bi-pencil-square fs-4"></i>
                    </div>
                    <div>
                        <h4 class="modal-title fw-bold text-dark mb-1">កែប្រែខ្លឹមសារអត្ថបទ</h4>
                        <p class="text-muted small mb-0">ធ្វើបច្ចុប្បន្នភាពព័ត៌មានអត្ថបទខាងក្រោម</p>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form method="post" asp-page-handler="EditBlog" enctype="multipart/form-data">
                <input type="hidden" asp-for="EditBlog.Id" id="EditBlog_Id" />
                <div class="modal-body px-4 px-md-5 py-3">
                    <div class="row g-4">
                        <div class="col-12">
                            <label asp-for="EditBlog.Title" class="form-label fw-bold text-secondary small">ចំណងជើងអត្ថបទ <span class="text-danger">*</span></label>
                            <input asp-for="EditBlog.Title" id="EditBlog_Title" class="form-control form-control-lg rounded-3 fs-6" required />
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-bold text-secondary small">រូបភាពក្របមុខ (Thumbnail) (ទុកទទេរ បើមិនចង់ប្តូរ)</label>
                            
                            <div class="mb-3">
                                <input type="url" name="ImageUrlLink" id="edit-image-link" class="form-control rounded-3 fs-6" 
                                       placeholder="ផាសតំណភ្ជាប់រូបភាពថ្មីនៅទីនេះ..." oninput="previewEditLinkImage(this.value)" />
                            </div>

                            <div class="border border-2 border-dashed rounded-4 p-4 text-center position-relative bg-light transition-hover">
                                <input type="file" name="UploadImage" id="edit-file-input" class="position-absolute top-0 start-0 w-100 h-100 opacity-0 cursor-pointer" accept="image/*" onchange="previewEditImage(event)" />
                                <div id="edit-image-preview-container">
                                    <img id="edit-image-preview" src="#" class="img-fluid rounded-3 shadow-sm object-fit-cover mb-2" style="max-height: 180px;" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <label asp-for="EditBlog.Content" class="form-label fw-bold text-secondary small">ខ្លឹមសារលម្អិតនៃអត្ថបទ <span class="text-danger">*</span></label>
                            <textarea asp-for="EditBlog.Content" id="EditBlog_Content" class="form-control rounded-3 fs-6" rows="8" required></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pb-4 pt-3 px-4 px-md-5">
                    <button type="button" class="btn btn-lg btn-light rounded-pill px-4 fs-6" data-bs-dismiss="modal">បោះបង់</button>
                    <button type="submit" class="btn btn-lg btn-warning text-dark rounded-pill px-5 fs-6 shadow-sm fw-bold">រក្សាទុកការកែប្រែ</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteBlogModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-md">
        <div class="modal-content border-0 shadow rounded-4 bg-white">
            <div class="modal-body p-4 text-center">
                <div class="text-danger display-3 mb-3"><i class="bi bi-exclamation-triangle-fill"></i></div>
                <h4 class="fw-bold text-dark mb-2">តើអ្នកពិតជាចង់លុបអត្ថបទនេះមែនទេ?</h4>
                <p class="text-muted small">អត្ថបទ៖ <span id="delete-blog-title" class="fw-bold text-danger"></span> នឹងត្រូវលុបបាត់បង់រហូត។</p>

                <form method="post" asp-page-handler="DeleteBlog" class="mt-4 d-flex justify-content-center gap-2">
                    <input type="hidden" name="id" id="delete-id" />
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">បោះបង់</button>
                    <button type="submit" class="btn btn-danger rounded-pill px-4 shadow-sm">យល់ព្រមលុប</button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .border-dashed { border-style: dashed !important; }
    .cursor-pointer { cursor: pointer; }
    .icon-shape { width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; }
    .bg-primary-subtle { background-color: #e3f2fd; }
    .bg-warning-subtle { background-color: #fff3e0; }
    .transition-hover { transition: background-color 0.2s ease; }
    .transition-hover:hover { background-color: #e9ecef !important; }
</style>

@section Scripts {
    <script>
        // Preview ពេល Upload ហ្វាយរូបភាពធម្មតា (Create)
        function previewCreateImage(event) {
            document.getElementById('create-image-link').value = ''; // សម្អាតប្រអប់ Link បើគាត់ជ្រើសរើសយកការ Upload ហ្វាយ
            var reader = new FileReader();
            reader.onload = function () {
                document.getElementById('create-image-preview').src = reader.result;
                document.getElementById('create-upload-prompt').classList.add('d-none');
                document.getElementById('create-image-preview-container').classList.remove('d-none');
            };
            if (event.target.files[0]) { reader.readAsDataURL(event.target.files[0]); }
        }

        // Preview ពេល ផាស Link រូបភាព (Create)
        function previewCreateLinkImage(url) {
            if(url.trim() !== "") {
                document.getElementById('create-file-input').value = ''; // សម្អាត File input បើគាត់ដាក់តាម Link វិញ
                document.getElementById('create-image-preview').src = url;
                document.getElementById('create-upload-prompt').classList.add('d-none');
                document.getElementById('create-image-preview-container').classList.remove('d-none');
            } else {
                document.getElementById('create-upload-prompt').classList.remove('d-none');
                document.getElementById('create-image-preview-container').classList.add('d-none');
            }
        }

        // Preview ពេល Upload ហ្វាយរូបភាពធម្មតា (Edit)
        function previewEditImage(event) {
            document.getElementById('edit-image-link').value = ''; 
            var reader = new FileReader();
            reader.onload = function () {
                document.getElementById('edit-image-preview').src = reader.result;
            };
            if (event.target.files[0]) { reader.readAsDataURL(event.target.files[0]); }
        }

        // Preview ពេល ផាស Link រូបភាព (Edit)
        function previewEditLinkImage(url) {
            if(url.trim() !== "") {
                document.getElementById('edit-file-input').value = '';
                document.getElementById('edit-image-preview').src = url;
            }
        }

        function openEditModal(id) {
            document.getElementById('EditBlog_Id').value = id;
            document.getElementById('EditBlog_Title').value = document.getElementById('title-' + id).innerText;
            document.getElementById('EditBlog_Content').value = document.getElementById('content-' + id).innerText;
            
            var imgSrc = document.getElementById('img-' + id).src;
            document.getElementById('edit-image-preview').src = imgSrc;

            // ប្រសិនបើរូបភាពចាស់ជាប្រភេទ Link ខាងក្រៅ រុញ Link នោះចូលប្រអប់ URL
            if(imgSrc.startsWith('http') && !imgSrc.includes('/images/blogs/')) {
                document.getElementById('edit-image-link').value = imgSrc;
            } else {
                document.getElementById('edit-image-link').value = '';
            }

            var myModal = new bootstrap.Modal(document.getElementById('editBlogModal'));
            myModal.show();
        }

        function openDeleteModal(id, title) {
            document.getElementById('delete-id').value = id;
            document.getElementById('delete-blog-title').innerText = title;

            var myModal = new bootstrap.Modal(document.getElementById('deleteBlogModal'));
            myModal.show();
        }
    </script>
}