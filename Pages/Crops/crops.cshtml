@page
@model PhumKasikam.Pages.Crops.CropsModel
@{
    ViewData["Title"] = "បញ្ជីដំណាំកសិកម្ម";
}

<link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

<div class="container mt-5 pt-4">
    <div class="text-center mb-5" data-aos="fade-down">
        <h2 class="fw-bold text-success display-5">
            <i class="bi bi-flower1"></i> បញ្ជីដំណាំកសិកម្ម
        </h2>
        <p class="text-muted fs-5">ស្វែងយល់ពីបច្ចេកទេសដាំដុះ និងការថែទាំដំណាំគ្រប់ប្រភេទ</p>
        <div class="mx-auto" style="width: 80px; height: 4px; background: #198754; border-radius: 2px;"></div>
    </div>

    <div class="row mb-5 justify-content-center" data-aos="fade-up" data-aos-delay="100">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-pill p-2 bg-white">
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-0"><i class="bi bi-search text-success"></i></span>
                    <input type="text" class="form-control border-0 shadow-none" placeholder="ស្វែងរកឈ្មោះដំណាំ...">
                    <button class="btn btn-success rounded-pill px-4">ស្វែងរក</button>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        @if (Model.Crops != null && Model.Crops.Any())
        {
            var delay = 100;
            @foreach (var item in Model.Crops)
            {
                <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="@delay">
                    <div class="card h-100 shadow-sm border-0 transition-hover overflow-hidden rounded-4">
                        <div class="position-relative overflow-hidden group">
                            
                            @if (string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="https://placehold.co/600x400?text=No+Image" class="card-img-top img-zoom" alt="@item.Name" style="height: 240px; object-fit: cover;">
                            }
                            else if (item.ImageUrl.StartsWith("http://") || item.ImageUrl.StartsWith("https://"))
                            {
                                <img src="@item.ImageUrl" class="card-img-top img-zoom" alt="@item.Name" style="height: 240px; object-fit: cover;">
                            }
                            else
                            {
                                <img src="@Url.Content("~" + item.ImageUrl)" class="card-img-top img-zoom" alt="@item.Name" style="height: 240px; object-fit: cover;">
                            }

                            <div class="position-absolute top-0 end-0 m-3">
                                <span class="badge glass-badge px-3 py-2 rounded-pill">
                                    @item.Category
                                </span>
                            </div>
                        </div>
                        
                        <div class="card-body p-4">
                            <h5 class="card-title fw-bold text-dark mb-3">@item.Name</h5>
                            <p class="card-text text-muted mb-4" style="font-size: 0.95rem; line-height: 1.6;">
                                @(item.Description != null && item.Description.Length > 110 ? item.Description.Substring(0, 110) + "..." : item.Description)
                            </p>
                        </div>
                        
                        <div class="card-footer bg-white border-0 px-4 pb-4 mt-auto">
                            <a href="/Crops/ShowNew" class="btn btn-outline-success w-100 rounded-pill fw-bold py-2 hover-fill">
                                <i class="bi bi-journal-richtext me-2"></i> មើលបច្ចេកទេស
                            </a>
                        </div>
                    </div>
                </div>
                delay += 50; // បង្កើន delay បន្តិចម្ដងៗ
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="alert alert-light border shadow-sm p-5 rounded-4">
                    <i class="bi bi-inbox text-muted fs-1"></i>
                    <p class="mt-3 text-muted">មិនទាន់មានទិន្នន័យដំណាំក្នុងតំបន់នៅឡើយទេ។</p>
                </div>
            </div>
        }
    </div>
</div>

<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        AOS.init({
            duration: 800,
            easing: 'ease-out-back',
            once: true
        });
    });
</script>

<style>
    /* UI Futuristic Style */
    .transition-hover {
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    .transition-hover:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 35px rgba(25, 135, 84, 0.15) !important;
    }

    /* Image Zoom Effect */
    .img-zoom {
        transition: transform 0.6s ease;
    }

    .card:hover .img-zoom {
        transform: scale(1.1);
    }

    /* Glassmorphism Badge */
    .glass-badge {
        background: rgba(25, 135, 84, 0.85);
        backdrop-filter: blur(4px);
        color: white;
        border: 1px solid rgba(255, 255, 255, 0.2);
        font-weight: 500;
    }

    /* Custom Button Hover */
    .hover-fill:hover {
        background-color: #198754;
        color: white !important;
    }

    /* Search Bar Shadow */
    .input-group input:focus {
        box-shadow: none;
    }
</style>