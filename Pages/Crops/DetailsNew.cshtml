@page
@model PhumKasikam.Pages.Crops.DetailsNewModel
@{
    ViewData["Title"] = Model.CropItem?.Name ?? "ព័ត៌មានលម្អិតដំណាំ";
}

<div class="container mt-5 pt-4">
    @if (Model.CropItem != null)
    {
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="mb-4">
                    <a href="javascript:history.back()" class="btn btn-light rounded-pill px-4 text-success fw-bold shadow-sm border-0">
                        <i class="bi bi-arrow-left me-2"></i> ត្រលប់ក្រោយ
                    </a>
                </div>

                <div class="bg-white rounded-5 p-4 p-md-5 shadow-sm border border-light mb-5">
                    <div class="row g-5">
                        <div class="col-md-6">
                            <div class="rounded-4 overflow-hidden bg-light shadow-sm position-sticky" style="top: 120px;">
                                @if (string.IsNullOrEmpty(Model.CropItem.ImageUrl))
                                {
                                    <img src="https://placehold.co/600x500" class="w-100 h-100 object-fit-cover img-fluid" alt="@Model.CropItem.Name">
                                }
                                else if (Model.CropItem.ImageUrl.StartsWith("http://") || Model.CropItem.ImageUrl.StartsWith("https://"))
                                {
                                    <img src="@Model.CropItem.ImageUrl" class="w-100 h-100 object-fit-cover img-fluid" alt="@Model.CropItem.Name">
                                }
                                else
                                {
                                    <img src="@Url.Content("~" + Model.CropItem.ImageUrl)" class="w-100 h-100 object-fit-cover img-fluid" alt="@Model.CropItem.Name">
                                }
                            </div>
                        </div>

                        <div class="col-md-6 d-flex flex-column justify-content-between">
                            <div>
                                <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill fw-bold mb-3">
                                    <i class="bi bi-shield-check me-1"></i> ផលិតផលធម្មជាតិពិតៗ
                                </span>
                                <h1 class="fw-bold text-dark lh-base mb-3">@Model.CropItem.Name</h1>
                                <hr class="my-4 opacity-50">
                                
                                <h5 class="fw-bold text-secondary mb-3"><i class="bi bi-info-circle me-2"></i>ពិពណ៌នាផលិតផល៖</h5>
                                <p class="text-muted lh-lg fs-5" style="white-space: pre-line; text-align: justify;">
                                    @Model.CropItem.Description
                                </p>
                            </div>

                            <div class="mt-4 p-4 bg-light rounded-4 border border-dashed border-2">
                                <div class="d-flex align-items-center gap-3 text-muted small">
                                    <i class="bi bi-telephone-fill text-success fs-4"></i>
                                    <div>
                                        <p class="mb-0 fw-bold text-dark">ទំនាក់ទំនងសាកសួរព័ត៌មានបន្ថែម</p>
                                        <p class="mb-0 small text-muted">ក្រុមការងារ ភូមិកសិកម្ម (Phum Kasikam)</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5 my-5">
            <i class="bi bi-exclamation-circle display-1 text-danger mb-3"></i>
            <h3 class="fw-bold">រកមិនឃើញទិន្នន័យផលិតផលនេះទេ!</h3>
            <p class="text-muted">ផលិតផលនេះអាចនឹងត្រូវលុប ឬគ្មានក្នុងប្រព័ន្ធ។</p>
            <a asp-page="/Crops/crops" class="btn btn-success rounded-pill px-4 mt-3">ត្រលប់ទៅបញ្ជីចម្បង</a>
        </div>
    }
</div>

<style>
    .bg-success-subtle { background-color: #e8f5e9; }
    .border-dashed { border-style: dashed !important; }
</style>